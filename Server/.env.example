PORT=5000
NODE_ENV=development

DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_DIALECT=mysql
DB_PORT=3306

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Frontend URL for CORS
CLIENT_URL=http://localhost:3000

RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Set this in Razorpay Dashboard → Webhooks → Secret. Required for webhook signature verification.
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

EMAIL_USER=your_email_address
EMAIL_PASS=your_email_app_password

ADMIN_EMAIL=admin@example.com

SHIPROCKET_EMAIL=your_shiprocket_email@example.com
SHIPROCKET_PWD="your_shiprocket_password"
SHIPROCKET_PICKUP_LOCATION=your_pickup_location